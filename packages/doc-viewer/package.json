{
  "name": "shrimp-doc-viewer",
  "version": "0.1.0",
  "description": "Browser, viewer-only, high-fidelity multi-format document viewer (PDF/Word/Excel/PPT). Rust/WASM core, pure-JS API.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjo4m06/shrimp-doc-viewer.git",
    "directory": "packages/doc-viewer"
  },
  "homepage": "https://github.com/cjo4m06/shrimp-doc-viewer#readme",
  "bugs": "https://github.com/cjo4m06/shrimp-doc-viewer/issues",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "src",
    "wasm",
    "fonts",
    "LICENSE-MIT",
    "LICENSE-APACHE",
    "THIRD-PARTY-NOTICES.txt"
  ],
  "sideEffects": [
    "./wasm/dv_wasm.js"
  ],
  "keywords": [
    "pdf",
    "docx",
    "xlsx",
    "pptx",
    "ppt",
    "powerpoint",
    "word",
    "excel",
    "csv",
    "markdown",
    "rtf",
    "odf",
    "odt",
    "viewer",
    "pdf-viewer",
    "docx-viewer",
    "office-viewer",
    "document-viewer",
    "file-preview",
    "image-viewer",
    "cjk",
    "chinese",
    "繁體中文",
    "rust",
    "webassembly",
    "wasm",
    "client-side",
    "no-server",
    "in-browser",
    "pdfium"
  ],
  "license": "MIT OR Apache-2.0",
  "dependencies": {
    "@embedpdf/pdfium": "^2.14.4"
  }
}
